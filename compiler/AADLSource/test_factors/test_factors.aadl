package Test_Factors
public
  with Base_Types;

  thread factor_tester
    features
      in_val   : in data port Base_Types::Integer;
      in_flag  : in data port Base_Types::Boolean;
      
      out_val  : out data port Base_Types::Integer;
      out_flag : out data port Base_Types::Boolean;
  end factor_tester;

  thread implementation factor_tester.i
    properties
      Dispatch_Protocol => Periodic;
      Period => 20 ms;
    annex Behavior_Specification {**
      variables
        temp_val  : Base_Types::Integer;
        temp_bool : Base_Types::Boolean;
        
      states
        s_ready : initial complete state;
        s_exec  : state;
        
      transitions
        s_ready -[ on dispatch ]-> s_exec;

        -- not
        t1: s_exec -[ not in_flag ]-> s_ready {
          temp_bool := not in_flag;
          out_flag := temp_bool
        };

        -- abs
        t2: s_exec -[ abs in_val = 10 ]-> s_ready {
          temp_val := abs in_val;
          out_val := temp_val
        };

        -- **
        t3: s_exec -[ in_val ** 2 > 100 ]-> s_ready {
          temp_val := in_val ** 3;
          out_val := temp_val
        };

        t4: s_exec -[ otherwise ]-> s_ready {
          out_val := 0;
          out_flag := false
        };
    **};
  end factor_tester.i;

  process test_proc
  end test_proc;

  process implementation test_proc.i
    subcomponents
      t : thread factor_tester.i;
  end test_proc.i;

  system root
  end root;

  system implementation root.i
    subcomponents
      p : process test_proc.i;
  end root.i;

end Test_Factors;