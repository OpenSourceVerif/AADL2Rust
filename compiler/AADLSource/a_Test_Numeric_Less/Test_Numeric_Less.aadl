package Test_Numeric_Less
public
    with Base_Types;

    thread monitor
    features
        sensor_val : in event data port Base_Types::Integer;
        alarm : out event port;
    end monitor;

    thread implementation monitor.i
    annex behavior_specification {**
    variables
        limit : Base_Types::Integer := 100;
        current : Base_Types::Integer;
    states
        idle : initial complete state;
        checking : state;
        unsafe : final state;
    transitions
        t1: idle -[ on dispatch sensor_val ]-> checking;

        -- 测试 number < identifier
        t2: checking -[ 10 < limit ]-> idle;

        -- 也可以测试 number < 端口/变量
        -- 如果 50 小于 limit，进入不安全状态
        t3: checking -[ 50 < limit ]-> unsafe {
            alarm!
        };
    **};
    end monitor.i;

    process monitor_proc
    features
        input : in event data port Base_Types::Integer;
    end monitor_proc;

    process implementation monitor_proc.i
    subcomponents
        m : thread monitor.i;
    connections
        c1: port input -> m.sensor_val;
    end monitor_proc.i;

    system root
    end root;

    system implementation root.i
    subcomponents
        p : process monitor_proc.i;
    end root.i;
end Test_Numeric_Less;